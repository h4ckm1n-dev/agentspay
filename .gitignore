# ---------------------------------------------------------------------------
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
ehthumbs.db
desktop.ini
*~

# ---------------------------------------------------------------------------
# Editors / IDE
# ---------------------------------------------------------------------------
.idea/
*.iml
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
*.swp
*.swo
.history/

# ---------------------------------------------------------------------------
# Environment + secrets
# ---------------------------------------------------------------------------
.env
.env.local
.env.*.local
*.pem
*.key

# MCP server config — contains API keys (e.g. 21st.dev Magic), operator-local.
.mcp.json

# ---------------------------------------------------------------------------
# Rust
# ---------------------------------------------------------------------------
/target
**/target/
**/*.rs.bk
*.pdb

# ---------------------------------------------------------------------------
# Node / pnpm / Next.js
# ---------------------------------------------------------------------------
node_modules
.pnpm-store
.turbo
dist
build
.next
out
coverage
*.tsbuildinfo
next-env.d.ts

# ---------------------------------------------------------------------------
# Python
# ---------------------------------------------------------------------------
__pycache__
*.py[cod]
*$py.class
.pytest_cache
.ruff_cache
.mypy_cache
.venv
venv
*.egg-info

# ---------------------------------------------------------------------------
# Local data + ledgers (devnet keypair + SQLite live in ~/.agentspay/,
# but if anyone ever runs the binary from this repo with default paths
# we still want to keep the artifacts out of git).
# ---------------------------------------------------------------------------
/.data
*.log
*.sqlite
*.sqlite-journal
*.db-shm
*.db-wal

# ---------------------------------------------------------------------------
# Agent tooling (Claude Code, gstack, superpowers)
# ---------------------------------------------------------------------------
.claude/
.superpowers/
.gstack/

# ---------------------------------------------------------------------------
# Docker compose env (operator-specific, contains DOMAIN + ACME_EMAIL)
# ---------------------------------------------------------------------------
docker/.env

# ---------------------------------------------------------------------------
# Backup files from sed/find-replace runs
# ---------------------------------------------------------------------------
*.bak
*.orig
